                },
                {
                    "type": "file",
                    "path": "lensfun_convert_db.py"
                },
                {
                    "type": "git",
                    "dest": "lensfun-git",
                    "url": "https://github.com/lensfun/lensfun.git",
                    "commit": "698a39eea69be00f4f25b6da6c1ad34b1f162b50"
                }
            ]
